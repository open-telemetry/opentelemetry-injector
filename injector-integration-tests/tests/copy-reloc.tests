# Regression tests for COPY relocations on glibc < 2.34.
#
# When an executable contains an R_*_COPY relocation for the environ symbol
# (e.g. /usr/local/bin/node from node:16-bullseye-slim, but more generally
# any binary that references `extern char **environ` and is not built as a
# PIE), ld.so allocates the canonical storage in the executable's BSS and
# rewires libc's own GOT entry to point at that copy.
#
# The injector resolves getenv at runtime (via dlsym or direct ELF lookup),
# so it always calls the correct libc function regardless of where the
# underlying environ storage lives. This ensures that pre-existing values
# of NODE_OPTIONS, OTEL_RESOURCE_ATTRIBUTES, OTEL_INJECTOR_K8S_*, etc. are
# visible to the injector and correctly merged or preserved.
#
# These tests use node:16-bullseye-slim, which ships glibc 2.31 and a node
# binary whose readelf output shows `R_AARCH64_COPY __environ`.

# These tests are glibc-specific: musl uses a different libc-detection path
# and does not exercise the affected fallback.
if [ "${LIBC_FLAVOR:-}" != "glibc" ]; then
  echo "Skipping copy-reloc tests: these tests are glibc-specific (LIBC_FLAVOR=${LIBC_FLAVOR:-unset})"
  return 0 2>/dev/null || true
fi

run_test_case \
  "copy reloc: injects NODE_OPTIONS when it is not present" \
  "app" \
  "node index.js NODE_OPTIONS" \
  "NODE_OPTIONS: --require /usr/lib/opentelemetry/nodejs/node_modules/@opentelemetry/auto-instrumentations-node/build/src/register.js"

run_test_case \
  "copy reloc: injects OTEL_RESOURCE_ATTRIBUTES from OTEL_INJECTOR_K8S_* when no pre-existing value" \
  "app" \
  "node index.js OTEL_RESOURCE_ATTRIBUTES" \
  "OTEL_RESOURCE_ATTRIBUTES: k8s.namespace.name=my-namespace,k8s.pod.name=my-pod,k8s.pod.uid=275ecb36-5aa8-4c2a-9c47-d8bb681b9aff,k8s.container.name=test-app"

run_test_case \
  "copy reloc: prepends to NODE_OPTIONS preserving pre-existing value" \
  "app" \
  "node index.js NODE_OPTIONS" \
  "NODE_OPTIONS: --require /usr/lib/opentelemetry/nodejs/node_modules/@opentelemetry/auto-instrumentations-node/build/src/register.js --no-deprecation" \
  "NODE_OPTIONS=--no-deprecation"

run_test_case \
  "copy reloc: merges OTEL_RESOURCE_ATTRIBUTES with pre-existing value" \
  "app" \
  "node index.js OTEL_RESOURCE_ATTRIBUTES" \
  "OTEL_RESOURCE_ATTRIBUTES: foo=bar,k8s.namespace.name=my-namespace,k8s.pod.name=my-pod,k8s.pod.uid=275ecb36-5aa8-4c2a-9c47-d8bb681b9aff,k8s.container.name=test-app" \
  "OTEL_RESOURCE_ATTRIBUTES=foo=bar"
